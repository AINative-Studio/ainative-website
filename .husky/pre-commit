#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# Pre-commit hook for AINative Studio Next.js
# Simplified after test suite cleanup (core#1406)

echo "Running pre-commit checks..."

# Run lint-staged for code formatting and linting
npx lint-staged

# Type checking
echo "Running TypeScript type checking..."
npm run type-check || {
  echo "Type check failed. Please fix type errors before committing."
  exit 1
}

# Run tests (no coverage gate while rebuilding test suite)
echo "Running tests..."
npm run test:coverage -- --passWithNoTests || {
  echo "Tests failed. Please fix failing tests before committing."
  exit 1
}

echo "All pre-commit checks passed!"
